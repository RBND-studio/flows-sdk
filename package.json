{
  "name": "@flows/monorepo",
  "description": "Flows monorepo",
  "private": true,
  "scripts": {
    "e2e": "pnpm --filter e2e",
    "js": "pnpm --filter js",
    "js-components": "pnpm --filter js-components",
    "react": "pnpm --filter react",
    "react-components": "pnpm --filter react-components",
    "shared": "pnpm --filter shared",
    "tsc": "pnpm -r tsc",
    "test": "pnpm -r test",
    "lint": "oxlint --type-aware",
    "commitlint": "commitlint --edit",
    "pre-push": "concurrently \"pnpm lint\" \"pnpm test\" \"pnpm tsc\" \"pnpm spellcheck\"",
    "prepare": "husky",
    "spellcheck": "cspell . --quiet"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@commitlint/types": "^20.5.0",
    "concurrently": "^9.2.1",
    "cspell": "^9.7.0",
    "husky": "^9.1.7",
    "minimist": "^1.2.8",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.14.2"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": "^24"
  }
}
