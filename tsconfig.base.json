{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "strict": true,
    "incremental": true,
    "noEmit": true,
    "target": "ES2017",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "lib": ["es2022", "dom"]
  },
  "include": []
}
